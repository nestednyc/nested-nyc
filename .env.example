# Supabase Configuration
# Copy this file to .env and fill in your actual values
# Get these from: https://app.supabase.com/project/_/settings/api
#
# For local development:
# 1. Copy this file: cp .env.example .env
# 2. Add your Supabase credentials below
# 3. Restart the dev server: npm run dev
#
# For production (Vercel):
# 1. Go to Vercel dashboard → Project Settings → Environment Variables
# 2. Add VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY
# 3. Redeploy your app

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ------------------------------------------------------------
# Server-only — used by the Vercel functions in /api
# (api/notify.js + api/unsubscribe.js). NOT exposed to the
# browser, so NO "VITE_" prefix. Set these in the Vercel
# dashboard (Production + Preview). See EMAIL_NOTIFICATIONS.md.
# ------------------------------------------------------------

# Same URL as VITE_SUPABASE_URL, without the prefix
SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase service-role key (Settings → API). Server-only secret — never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Supabase ANON key — same value as VITE_SUPABASE_ANON_KEY, without the prefix.
# Used by api/prerender.js + api/sitemap.js so RLS enforces public visibility
# (never use the service-role key there — it would leak private rows into public HTML).
SUPABASE_ANON_KEY=your-anon-key-here
# Resend API key for the notification sender (api/notify.js). Named
# RESEND_VERCEL_KEY in Vercel to avoid clashing with the Resend key Supabase
# Auth's SMTP uses. (notify.js also accepts RESEND_API_KEY as a fallback.)
RESEND_VERCEL_KEY=your-resend-api-key
# Shared secret the Supabase Database Webhooks send as the `x-webhook-secret` header
WEBHOOK_SECRET=generate-a-long-random-string
# From address — the domain must be verified in Resend
EMAIL_FROM=Nested <hi@nested.social>
# Public app origin, used to build links inside emails
APP_URL=https://www.nested.social
# Optional: dedicated HMAC secret for unsubscribe links (defaults to WEBHOOK_SECRET)
UNSUBSCRIBE_SECRET=
